{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": false,
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "target": "es2022",
    "loose": false,
    "keepClassNames": true,
    "externalHelpers": false
  },
  "module": {
    "type": "nodenext"
  },
  "sourceMaps": "inline",
  "inputSourceMap": false
}
