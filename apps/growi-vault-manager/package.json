{
  "name": "@growi/vault-manager",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:vault-manager": "node --import @swc-node/register/esm-register src/index.ts",
    "dev:vault-manager:ci": "node --import @swc-node/register/esm-register src/index.ts --ci",
    "start:prod": "node dist/index.js",
    "start:prod:ci": "pnpm start:prod --ci",
    "lint:biome": "biome check",
    "lint:typecheck": "tsc --noEmit",
    "lint": "run-p lint:**",
    "build": "pnpm tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@godaddy/terminus": "^4.12.1",
    "@growi/core": "workspace:^",
    "@growi/logger": "workspace:^",
    "@tsed/common": "=8.5.0",
    "@tsed/components-scan": "=8.5.0",
    "@tsed/core": "=8.5.0",
    "@tsed/di": "=8.5.0",
    "@tsed/exceptions": "=8.5.0",
    "@tsed/json-mapper": "=8.5.0",
    "@tsed/logger": ">=7.0.2",
    "@tsed/platform-express": "=8.5.0",
    "@tsed/platform-http": "=8.5.0",
    "@tsed/schema": "=8.5.0",
    "@tsed/swagger": "=8.5.0",
    "@tsed/terminus": "=8.5.0",
    "express": "^4.19.2",
    "isomorphic-git": "^1.37.0",
    "mongoose": "^6.13.6",
    "tslib": "^2.8.0"
  },
  "devDependencies": {
    "@swc-node/register": "^1.10.9",
    "@swc/core": "^1.9.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.18.3",
    "unplugin-swc": "^1.5.3",
    "vitest": "^2.0.0"
  }
}
