{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // This app stays on the JS-based TypeScript 6 line (tsc6): its CommonJS +
    // node10 resolution and baseUrl are removed in TypeScript 7. Silence the
    // 6.x deprecation errors until the app is modernized.
    "ignoreDeprecations": "6.0",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "paths": {
      "~/*": ["./src/*"],
      // force package to local node_modules since pnpm reads wrong hoisted tsed version used in pdf-converter (https://github.com/pnpm/pnpm/issues/7158)
      "@tsed/core": ["./node_modules/@tsed/core"],
      "@tsed/schema": ["./node_modules/@tsed/schema"],
      "@tsed/exceptions": ["./node_modules/@tsed/exceptions"],
      "@tsed/common": ["./node_modules/@tsed/common"],
      "@tsed/di": ["./node_modules/@tsed/di"],
      "@tsed/logger": ["./node_modules/@tsed/logger"]
    },

    /* TODO: remove below flags for strict checking */
    "strict": false,
    "strictNullChecks": true,
    "strictBindCallApply": true,
    "noImplicitAny": false,
    "noImplicitOverride": true

    /* Path aliases in build output (.js and .d.ts) are rewritten to relative
       form by tsc-alias in the build script (formerly typescript-transform-paths
       via tspc). */
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "config",
    "dist",
    "src/public/**",
    "**/*.test.ts"
  ],
  "ts-node": {
    "transpileOnly": true,
    "swc": true
  }
}
