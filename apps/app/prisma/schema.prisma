model activities {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  v           Int                @map("__v")
  action      String
  createdAt   DateTime           @default(now())
  // ip/endpoint are optional as a safeguard: the legacy Mongoose schema never
  // required them, and some write paths still omit them today, so documents
  // without either field are expected, not corrupt.
  endpoint    String?
  event       String?            @db.ObjectId
  eventModel  String?
  ip          String?
  snapshot    ActivitiesSnapshot
  target      String?            @db.ObjectId
  targetModel String?
  userId      String?            @map("user") @db.ObjectId

  user users? @relation(fields: [userId], references: [id])

  @@unique([userId, target, action, createdAt], map: "user_1_target_1_action_1_createdAt_1")
  @@index([userId], map: "user_1")
  @@index([snapshot.username], map: "snapshot.username_1")
  @@index([target, action], map: "target_1_action_1")
  @@index([createdAt], map: "createdAt_1")
}

