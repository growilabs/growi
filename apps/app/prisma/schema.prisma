  creator        users?        @relation("CreatedPages", fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lastUpdateUser users?        @relation("LastUpdatedPages", fields: [lastUpdateUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parent         pages?        @relation("ParentChild", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children       pages[]       @relation("ParentChild")
  deleteUser     users?        @relation("DeletedPages", fields: [deleteUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  revisions      revisions[]
  comments       comments[]
  attachments    attachments[]
  bookmarks      bookmarks[]

  @@index([parentId], map: "parent_1")
  @@index([path], map: "path_1")
  @@index([status], map: "status_1")
  @@index([grant], map: "grant_1")
  @@index([creatorId], map: "creator_1")
  @@index([createdAt], map: "createdAt_1")
  @@index([updatedAt], map: "updatedAt_1")
  @@index([ttlTimestamp], map: "ttlTimestamp_1")
}

