  creatorId                String?   @map("creator") @db.ObjectId
  deletedAt                DateTime?
  deleteUserId             String?   @map("deleteUser") @db.ObjectId
  descendantCount          Int       @default(0)
  expandContentWidth       Boolean?
  grant                    Int       @default(1)
  /// Nested objects had no data in the sample dataset to introspect a nested type.
  grantedGroups            Json?
