  originalName          String?
  temporaryUrlCached    String?
  temporaryUrlExpiredAt DateTime?
  attachmentType        String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  creator              users?  @relation("CreatedAttachments", fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  page                 pages?  @relation(fields: [pageId], references: [id])
  userImageAttachments users[] @relation("UserImageAttachment")

  @@index([pageId], map: "page_1")
  @@index([creatorId], map: "creator_1")
}

