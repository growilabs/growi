{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Use Preserve/Bundler resolution so that extensionless relative specifiers
    // are accepted during type-checking. The server build emits real Node ESM
    // by running add-js-extensions (C1) in postbuild after tspc finishes.
    // NodeNext shims (server-build-shims/) are no longer needed because Bundler
    // resolution uses esModuleInterop-style default imports natively.
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "outDir": "transpiled",
    "declaration": true,
    "noResolve": false,
    "preserveConstEnums": true,
    "sourceMap": false,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "^/*": ["./*"]
    }
  },
  "exclude": [
    "config/ci",
    "config/*.js",
    "config/*.spec.ts",
    "resource",
    "src/client",
    "src/components",
    "src/components-universal",
    "src/linter-checker",
    "src/stores",
    "src/stores-universal",
    "src/styles",
    "src/**/*.jsx",
    "src/**/*.tsx",
    "src/**/*.spec.ts",
    "src/**/*.integ.ts"
  ]
}
